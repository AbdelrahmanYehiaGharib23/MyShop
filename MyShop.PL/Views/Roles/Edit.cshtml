@model RoleViewModel

@{
    ViewData["Title"] = "Edit Role";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<partial name="_IdentityManagementStyles" />

<section class="identity-shell identity-form">
    <div class="identity-toolbar">
        <div>
            <span class="identity-kicker">Security groups</span>
            <h2 class="identity-title">Edit Role</h2>
            <p class="identity-copy">Rename the role or manage the users assigned to it.</p>
        </div>
    </div>

    <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <partial name="PartialViews/_RoleEditableFields" model="Model" />

        <div class="identity-action-group mt-4">
            <button class="identity-primary-action border-0" type="submit">
                <i class="fas fa-save"></i>
                <span>Save</span>
            </button>
            <a asp-action="AddOrRemoveUsers" class="identity-secondary-action" asp-route-roleId="@Model.Id">
                <i class="fas fa-users-cog"></i>
                <span>Manage Users</span>
            </a>
            <a class="identity-secondary-action" asp-action="Index">
                <i class="fas fa-arrow-left"></i>
                <span>Cancel</span>
            </a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
