@using MyShop.BLL.Models.Dto.IdentityDto

@model ResetPasswordDto
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Reset Password";
}

<div class="auth-card">
    <div class="auth-step-icon">
        <i class="fas fa-unlock-keyhole"></i>
    </div>

    <h2 class="auth-title">Reset Password</h2>
    <p class="auth-subtitle">Create a new password for your EMS account.</p>

    <form asp-action="ResetPassword" method="post" class="auth-form">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        <input asp-for="Token" type="hidden" />

        <div class="input-group">
            <span class="input-icon"><i class="fas fa-lock"></i></span>
            <input asp-for="NewPassword" type="password" placeholder="New Password" required />
        </div>
        <span asp-validation-for="NewPassword" class="field-validation-error"></span>

        <button type="submit" class="auth-btn">RESET PASSWORD</button>
    </form>

    <p class="switch-form">Back to <a asp-action="Login" asp-controller="Account">Login</a></p>
</div>
