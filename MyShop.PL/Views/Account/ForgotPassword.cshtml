@using MyShop.BLL.Models.Dto.IdentityDto

@model ForgotPasswordDto
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-card">
    <div class="auth-step-icon">
        <i class="fas fa-key"></i>
    </div>

    <h2 class="auth-title">Forgot Password</h2>
    <p class="auth-subtitle">Enter your email and we will send you a verification code.</p>

    <form asp-action="ForgotPassword" method="post" class="auth-form">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="input-group">
            <span class="input-icon"><i class="fas fa-envelope"></i></span>
            <input asp-for="Email" placeholder="Email" required />
        </div>
        <span asp-validation-for="Email" class="field-validation-error"></span>

        <button type="submit" class="auth-btn">SEND OTP</button>
    </form>

    @if (ViewBag.Message != null)
    {
        <div class="auth-alert auth-alert-success">@ViewBag.Message</div>
    }

    <p class="switch-form">Remembered your password? <a asp-action="Login" asp-controller="Account">Login Now!</a></p>
</div>
