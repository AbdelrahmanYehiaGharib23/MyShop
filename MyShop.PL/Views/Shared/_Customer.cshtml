<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@(ViewData["Title"] is null ? "myShop" : $"{ViewData["Title"]} - myShop")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css" />
    <style>
        :root {
            --shop-ink: #17202a;
            --shop-muted: #6b7785;
            --shop-border: #dfe5ed;
            --shop-accent: #0f9f8f;
            --shop-warm: #f59e0b;
            --shop-bg: #f6f8fb;
        }

        body {
            min-height: 100vh;
            margin: 0;
            background: var(--shop-bg);
            color: var(--shop-ink);
        }

        .store-nav {
            border-bottom: 1px solid var(--shop-border);
            background: #fff;
            box-shadow: 0 10px 24px rgba(23, 32, 42, .06);
        }

        .store-brand {
            color: var(--shop-ink);
            font-size: 1.45rem;
            font-weight: 800;
            letter-spacing: 0;
        }

        .store-brand:hover {
            color: var(--shop-accent);
        }

        .store-link {
            color: var(--shop-muted);
            font-weight: 700;
        }

        .store-link:hover,
        .store-link.active {
            color: var(--shop-accent);
        }

        .store-hero {
            border-bottom: 1px solid var(--shop-border);
            background:
                linear-gradient(120deg, rgba(23, 32, 42, .94), rgba(15, 159, 143, .84)),
                url('/img/photo1.png') center/cover;
            color: #fff;
            padding: 4rem 0 4.5rem;
        }

        .store-hero h1 {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 800;
            letter-spacing: 0;
        }

        .store-hero p {
            max-width: 640px;
            margin: .75rem 0 0;
            color: rgba(255, 255, 255, .82);
            font-size: 1.05rem;
        }

        .store-main {
            padding: 2rem 0 3rem;
        }

        .store-footer {
            border-top: 1px solid var(--shop-border);
            background: #17202a;
            color: rgba(255, 255, 255, .75);
            padding: 1.25rem 0;
        }

        .store-footer strong {
            color: #fff;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg store-nav">
        <div class="container">
            <a class="navbar-brand store-brand" asp-controller="Product" asp-action="Index">myShop</a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#storeNavbar"
                    aria-controls="storeNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="storeNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link store-link" asp-controller="Product" asp-action="Index">Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link store-link" asp-controller="Category" asp-action="Index">Categories</a>
                    </li>
                </ul>

                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <header class="store-hero">
        <div class="container">
            <h1>myShop</h1>
            <p>Browse products and manage the catalog through a focused, clean shopping experience.</p>
        </div>
    </header>

    <main class="store-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="store-footer">
        <div class="container">
            <strong>myShop</strong> &copy; @DateTime.Now.Year
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
