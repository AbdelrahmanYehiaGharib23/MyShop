@{
    var pageTitle = ViewData["Title"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var contentTitle = ViewBag.PageTitle as string ?? pageTitle ?? "Admin Console";
    var cardTitle = ViewBag.CardTitle as string ?? pageTitle ?? "Overview";
    var roleName = User.IsInRole("Admin") ? "Admin" : User.IsInRole("Customer") ? "Customer":"Customer";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@(string.IsNullOrWhiteSpace(pageTitle) ? "myShop Admin" : $"{pageTitle} - myShop Admin")</title>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap">
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="~/css/adminlte.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css">
    <link rel="stylesheet" href="//cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">

    <style>
        :root {
            --admin-ink: #17202a;
            --admin-sidebar: #1f2a35;
            --admin-sidebar-deep: #121a22;
            --admin-sidebar-soft: #2d4050;
            --admin-accent: #0f9f8f;
            --admin-accent-warm: #f59e0b;
            --admin-bg: #f5f7fb;
            --admin-surface: #ffffff;
            --admin-border: #dfe5ed;
            --admin-muted: #6b7785;
            --sidebar-panel-bg: rgba(18, 26, 34, .82);
            --sidebar-panel-border: rgba(255, 255, 255, .12);
            --sidebar-text-dim: rgba(255, 255, 255, .64);
        }

        body,
        .nav-link,
        .brand-text,
        .content-wrapper {
            font-family: 'Poppins', sans-serif;
        }

        .main-sidebar {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background: linear-gradient(180deg, var(--admin-sidebar-deep) 0%, var(--admin-sidebar) 46%, var(--admin-sidebar-soft) 100%);
        }

        .main-sidebar .sidebar {
            flex: 1 1 auto;
            min-height: 0;
            height: auto;
        }

        .brand-link {
            min-height: 64px;
            background: rgba(18, 26, 34, .96);
            border-bottom: 1px solid rgba(255, 255, 255, .1);
            color: #fff;
            font-weight: 700;
        }

        .brand-link:hover {
            color: #fff;
        }

        .brand-text {
            letter-spacing: 0;
        }

        .main-header {
            border-bottom: 1px solid var(--admin-border);
        }

        .admin-navbar-title {
            color: var(--admin-ink);
            font-weight: 700;
        }

        .admin-navbar-subtitle {
            color: var(--admin-muted);
            font-size: 12px;
            font-weight: 500;
        }

        .admin-user-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--admin-ink);
            font-weight: 600;
        }

        .admin-user-chip i {
            color: var(--admin-accent);
        }

        .nav-sidebar > .nav-item > .nav-link {
            border-radius: 8px;
            margin-bottom: 6px;
            color: rgba(255, 255, 255, .82);
            transition: background-color .2s ease, color .2s ease, transform .2s ease;
        }

        .nav-sidebar > .nav-item > .nav-link:hover {
            background: rgba(255, 255, 255, .1);
            color: #fff;
            transform: translateX(2px);
        }

        .nav-sidebar > .nav-item > .nav-link.active {
            background: linear-gradient(90deg, var(--admin-accent), var(--admin-accent-warm));
            color: #fff;
            box-shadow: 0 8px 20px rgba(15, 159, 143, .22);
        }

        .nav-sidebar .nav-icon {
            width: 1.35rem;
        }

        .content-wrapper {
            background: var(--admin-bg);
        }

        .content-header {
            padding: 20px 1rem 10px;
        }

        .content-header h1 {
            color: var(--admin-ink);
            font-size: 1.55rem;
            font-weight: 700;
            margin: 0;
        }

        .admin-card {
            border: 1px solid var(--admin-border);
            border-radius: 8px;
            box-shadow: 0 14px 35px rgba(23, 32, 42, .08);
            overflow: hidden;
        }

        .admin-card > .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 56px;
            background: var(--admin-surface);
            border-bottom: 1px solid var(--admin-border);
            color: var(--admin-ink);
        }

        .admin-card .card-title {
            color: var(--admin-ink);
            font-size: 1rem;
            font-weight: 700;
        }

        .admin-card .btn-tool {
            color: var(--admin-muted);
        }

        .admin-card .btn-tool:hover {
            color: var(--admin-accent);
        }

        .admin-card > .card-body {
            background: var(--admin-surface);
            padding: 1.25rem;
        }

        .footer-dark {
            background: #17202a;
            border-top: 0;
            color: rgba(255, 255, 255, .8);
        }

        .footer-dark strong,
        .footer-dark b {
            color: #fff;
        }

        .user-panel img {
            border: 2px solid white;
        }

        .sidebar-account-panel {
            border-top: 1px solid var(--sidebar-panel-border);
        }

        .sidebar-account-card {
            background: var(--sidebar-panel-bg);
            border: 1px solid var(--sidebar-panel-border);
            border-radius: 8px;
            padding: 14px;
            backdrop-filter: blur(6px);
        }

        .sidebar-account-avatar-wrap {
            position: relative;
            flex-shrink: 0;
        }

        .sidebar-account-status-dot {
            position: absolute;
            bottom: 1px;
            right: 1px;
            width: 10px;
            height: 10px;
            background: #27c77b;
            border: 2px solid #14213d;
            border-radius: 50%;
        }

        .sidebar-account-name {
            max-width: 140px;
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.2;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .sidebar-account-role {
            color: var(--sidebar-text-dim);
            font-size: 12px;
        }

        .sidebar-logout-divider {
            border: none;
            border-top: 1px solid var(--sidebar-panel-border);
            margin: 12px 0;
        }

        .btn-logout,
        .btn-login-sidebar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            transition: .2s ease;
        }

        .btn-logout {
            color: #ff6b6b;
            background: rgba(255, 107, 107, .08);
            border: 1px solid rgba(255, 107, 107, .35);
        }

        .btn-logout:hover,
        .btn-logout:focus {
            background: #ff6b6b;
            border-color: #ff6b6b;
            color: #fff;
            box-shadow: 0 4px 12px rgba(255, 107, 107, .28);
        }

        .btn-login-sidebar {
            color: var(--admin-accent);
            background: rgba(15, 159, 143, .1);
            border: 1px solid rgba(15, 159, 143, .35);
        }

        .btn-login-sidebar:hover,
        .btn-login-sidebar:focus {
            background: var(--admin-accent);
            border-color: var(--admin-accent);
            color: #fff;
            box-shadow: 0 4px 12px rgba(15, 159, 143, .26);
        }

        .sidebar-collapse .sidebar-account-panel {
            padding: .5rem !important;
        }

        .sidebar-collapse .sidebar-account-card {
            padding: 8px 4px;
            background: transparent;
            border: none;
        }

        .sidebar-collapse .sidebar-account-card .d-flex.align-items-center {
            justify-content: center;
        }

        .sidebar-collapse .sidebar-account-avatar-wrap img {
            width: 34px;
            height: 34px;
        }

        .sidebar-collapse .sidebar-account-card .ml-3,
        .sidebar-collapse .sidebar-logout-divider,
        .sidebar-collapse .btn-logout span,
        .sidebar-collapse .btn-login-sidebar span {
            display: none;
        }

        .sidebar-collapse .btn-logout,
        .sidebar-collapse .btn-login-sidebar {
            width: 34px;
            height: 34px;
            padding: 0;
            margin: 8px auto 0;
            border-radius: 50%;
        }
    </style>
</head>


<body class="hold-transition sidebar-mini">
    <div class="wrapper">
        <nav class="main-header navbar navbar-expand navbar-white navbar-light shadow-sm">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" aria-label="Toggle navigation">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
                <li class="nav-item d-none d-sm-flex flex-column justify-content-center ml-2">
                    <span class="admin-navbar-title">Admin Console</span>
                    <span class="admin-navbar-subtitle">Catalog and security management</span>
                </li>
            </ul>

            <ul class="navbar-nav ml-auto">
                <li class="nav-item d-none d-md-flex align-items-center pr-3">
                    <span class="admin-user-chip">
                        <i class="fas fa-user-circle"></i>
                        @(User.Identity?.Name ?? "Guest")
                    </span>
                </li>
            </ul>
        </nav>

        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a asp-controller="Product" asp-action="Index" class="brand-link">
                <img src="~/img/AdminLTELogo.png"
                     class="brand-image img-circle elevation-3"
                     style="opacity:.9"
                     alt="myShop logo">
                <span class="brand-text">myShop Admin</span>
            </a>

            <div class="sidebar d-flex flex-column">
                <nav class="mt-3">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                        <li class="nav-item">
                            <a asp-controller="Product"
                               asp-action="Index"
                               class="nav-link @(string.Equals(currentController, "Product", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)">
                                <i class="nav-icon fas fa-box-open"></i>
                                <p>Products</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Category"
                               asp-action="Index"
                               class="nav-link @(string.Equals(currentController, "Category", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)">
                                <i class="nav-icon fas fa-tags"></i>
                                <p>Categories</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="User"
                               asp-action="Index"
                               class="nav-link @(string.Equals(currentController, "User", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)">
                                <i class="nav-icon fas fa-users"></i>
                                <p>Users</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Roles"
                               asp-action="Index"
                               class="nav-link @(string.Equals(currentController, "Roles", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)">
                                <i class="nav-icon fas fa-user-shield"></i>
                                <p>Roles</p>
                            </a>
                        </li>
                    </ul>
                </nav>

                <div class="mt-auto p-3 sidebar-account-panel">
                    <div class="sidebar-account-card">
                        <div class="d-flex align-items-center">
                            <div class="sidebar-account-avatar-wrap">
                                <img src="~/img/user2-160x160.jpg"
                                     class="img-circle elevation-2"
                                     width="42"
                                     height="42"
                                     alt="Admin user">
                                <span class="sidebar-account-status-dot" title="Online"></span>
                            </div>
                     
                            <div class="ml-3"> <div class="sidebar-account-name"> @(User.Identity?.Name ?? "Administrator") </div>
                          <div class="sidebar-account-role"> @roleName account </div> 
                          </div>
                          </div>

                        <hr class="sidebar-logout-divider">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-logout">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Logout</span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn-login-sidebar">
                                <i class="fas fa-sign-in-alt"></i>
                                <span>Login</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </aside>

        <div class="content-wrapper">
            <section class="content-header">
                <div class="container-fluid">
                    <h1>@contentTitle</h1>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="card admin-card">
                        <div class="card-header">
                            <h3 class="card-title">@cardTitle</h3>
                            <div class="card-tools">
                                <button type="button"
                                        class="btn btn-tool"
                                        data-card-widget="collapse"
                                        aria-label="Collapse card">
                                    <i class="fas fa-minus"></i>
                                </button>
                            </div>
                        </div>

                        <div class="card-body">
                            <partial name="_Toaster" />
                            @RenderBody()
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <footer class="main-footer footer-dark">
            <strong>&copy; @DateTime.Now.Year myShop.</strong>
            All rights reserved.
        </footer>
    </div>

    <script src="~/plugins/jquery/jquery.min.js"></script>
    <script src="~/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/adminlte.min.js"></script>
    <script src="//cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
