@using myshop.Entities.ViewModels
@model ProductVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.PageTitle = "Product Management";
    ViewBag.CardTitle = "Edit Product";
    ViewData["FormMode"] = "Edit";
    ViewData["FormAction"] = "Edit";
    ViewData["SubmitText"] = "Save Changes";
    ViewData["FormIntro"] = "Keep product content accurate, complete, and ready for customers.";
}

<partial name="PartialView/_ProductStyles" />

<section class="product-shell product-narrow">
    <partial name="PartialView/_ProductForm" model="Model ?? new ProductVM()" />
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
