@using MyShop.BLL.Models.Dto.ProductDto
@model ProductDto

<article class="product-card">
    <div class="product-card-media">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" />
        }
        else
        {
            <div class="product-image-fallback">
                <i class="fas fa-image"></i>
            </div>
        }
        <span class="product-category-pill">@Model.CategoryName</span>
    </div>
    <div class="product-card-body">
        <h3>@Model.Name</h3>
        <div class="product-card-meta">
            <strong>@Model.Price.ToString("C")</strong>
            <span>ID: @Model.Id</span>
        </div>
        <div class="product-card-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="product-secondary-action">
                <i class="fas fa-pen"></i>
                <span>Edit</span>
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="product-danger-link">
                <i class="fas fa-trash"></i>
                <span>Delete</span>
            </a>
        </div>
    </div>
</article>
