@using MyShop.BLL.Models.Dto.ProductDto
@model IEnumerable<ProductDto>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.PageTitle = "Product Management";
    ViewBag.CardTitle = "Products";
    var products = (Model ?? Enumerable.Empty<ProductDto>()).ToList();
}

<partial name="PartialView/_ProductStyles" />

<section class="product-shell">
    @if (TempData["Message"] is not null)
    {
        <div class="product-alert">
            <i class="fas fa-info-circle"></i>
            <span>@TempData["Message"]</span>
        </div>
    }

    @if (TempData["SuccessMessage"] is not null)
    {
        <div class="product-alert success">
            <i class="fas fa-check-circle"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="product-toolbar">
        <div>
            <span class="product-kicker">Store inventory</span>
            <h2>Products</h2>
            <p>Manage product presentation, pricing, images, and category placement.</p>
        </div>
        <a asp-action="Create" class="product-primary-action">
            <i class="fas fa-plus"></i>
            <span>New Product</span>
        </a>
    </div>

    <div class="product-metrics">
        <div>
            <span>Total products</span>
            <strong>@products.Count</strong>
        </div>
        <div>
            <span>Categories in use</span>
            <strong>@products.Select(product => product.CategoryName).Distinct().Count()</strong>
        </div>
        <div>
            <span>Average price</span>
            <strong>@(products.Any() ? products.Average(product => product.Price).ToString("C") : "0")</strong>
        </div>
    </div>

    @if (products.Any())
    {
        <div class="product-grid">
            @foreach (var product in products)
            {
                var imageUrl = string.IsNullOrWhiteSpace(product.ImageUrl)
                    ? null
                    : Url.Content($"~/{product.ImageUrl.TrimStart('/')}");

                <article class="product-card">
                    <div class="product-card-media">
                        @if (!string.IsNullOrWhiteSpace(imageUrl))
                        {
                            <img src="@imageUrl" alt="@product.Name" />
                        }
                        else
                        {
                            <div class="product-image-fallback">
                                <i class="fas fa-image"></i>
                            </div>
                        }
                        <span class="product-category-pill">@product.CategoryName</span>
                    </div>

                    <div class="product-card-body">
                        <h3>@product.Name</h3>
                        <div class="product-card-meta">
                            <strong>@product.Price.ToString("C")</strong>
                            <span>@product.CategoryName</span>
                        </div>
                        <div class="product-card-actions">
                            <a asp-action="Details" asp-route-id="@product.Id" class="product-secondary-action">
                                <i class="fas fa-eye"></i>
                                <span>Details</span>
                            </a>
                            <a asp-action="Edit" asp-route-id="@product.Id" class="product-secondary-action">
                                <i class="fas fa-edit"></i>
                                <span>Edit</span>
                            </a>
                            <a asp-action="Delete" asp-route-id="@product.Id" class="product-danger-link">
                                <i class="fas fa-trash"></i>
                                <span>Delete</span>
                            </a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="product-empty">
            <i class="fas fa-box-open"></i>
            <h3>No products yet</h3>
            <p>Add the first product and start shaping the storefront experience.</p>
            <a asp-action="Create" class="product-primary-action">
                <i class="fas fa-plus"></i>
                <span>Create Product</span>
            </a>
        </div>
    }
</section>
