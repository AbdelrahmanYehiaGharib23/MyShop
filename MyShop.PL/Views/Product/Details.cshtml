@using MyShop.BLL.Models.Dto.ProductDto
@model ProductDetailsDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.PageTitle = "Product Management";
    ViewBag.CardTitle = "Product Details";
    var imageUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? null
        : Url.Content($"~/{Model.ImageUrl.TrimStart('/')}");
}

<partial name="PartialView/_ProductStyles" />

<section class="product-shell product-narrow">
    <div class="product-delete-panel">
        <div class="product-delete-media">
            @if (!string.IsNullOrWhiteSpace(imageUrl))
            {
                <img src="@imageUrl" alt="@Model.Name" />
            }
            else
            {
                <div class="product-image-fallback">
                    <i class="fas fa-image"></i>
                </div>
            }
        </div>

        <div class="product-delete-copy">
            <span class="product-kicker">Product details</span>
            <h2>@Model.Name</h2>
            <p>@Model.Description</p>
            <dl>
                <div>
                    <dt>Price</dt>
                    <dd>@Model.Price.ToString("C")</dd>
                </div>
                <div>
                    <dt>Category</dt>
                    <dd>@Model.CategoryName</dd>
                </div>
            </dl>
        </div>
    </div>

    <div class="product-confirm-row product-form-actions">
        <a asp-action="Index" class="product-secondary-action">
            <i class="fas fa-arrow-left"></i>
            <span>Back</span>
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="product-primary-action">
            <i class="fas fa-edit"></i>
            <span>Edit Product</span>
        </a>
    </div>
</section>
