@using myshop.Entities.ViewModels
@model ProductVM

@{
    Layout = "~/Views/Shared/_Dashboard.cshtml";
    ViewBag.PageTitle = "Product Management";
    ViewBag.CardTitle = "Create Product";
    ViewData["FormMode"] = "Create";
    ViewData["FormAction"] = "Create";
    ViewData["SubmitText"] = "Create Product";
    ViewData["FormIntro"] = "Add product details customers need before they decide to buy.";
}

<partial name="_ProductStyles" />

<section class="product-shell product-narrow">
    <partial name="_ProductMessages" />
    <partial name="_ProductForm" model="Model ?? new ProductVM()" />
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_ProductPreviewScript" />
}
