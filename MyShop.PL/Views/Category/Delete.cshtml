@using MyShop.BLL.Models.Dto.CategoryDto
@model CategoryDetailsDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.PageTitle = "Category Management";
    ViewBag.CardTitle = "Delete Category";
}

<partial name="PartialView/_CategoryStyles" />

<section class="catalog-shell catalog-narrow">
    <partial name="PartialView/_CategoryMessages" />

    <div class="catalog-danger-panel">
        <div class="catalog-danger-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <div>
            <span class="catalog-kicker">Delete confirmation</span>
            <h2>@Model.Name</h2>
            <p>This category is connected to @Model.ProductsCount product(s). Confirm only when you are sure this should be removed from the catalog.</p>
        </div>
    </div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="catalog-confirm-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="catalog-confirm-row">
            <a asp-action="Index" class="catalog-secondary-action">
                <i class="fas fa-arrow-left"></i>
                <span>Back</span>
            </a>
            <button type="submit" class="catalog-danger-action">
                <i class="fas fa-trash"></i>
                <span>Delete Category</span>
            </button>
        </div>
    </form>
</section>
