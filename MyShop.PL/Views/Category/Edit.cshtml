@using MyShop.PL.ViewModels
@model CategoryVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.PageTitle = "Category Management";
    ViewBag.CardTitle = "Edit Category";
    ViewData["FormMode"] = "Edit";
    ViewData["FormAction"] = "Edit";
    ViewData["SubmitText"] = "Save Changes";
    ViewData["FormIntro"] = "Refine category naming so the storefront remains easy to browse.";
}

<partial name="PartialView/_CategoryStyles" />

<section class="catalog-shell catalog-narrow">
    <partial name="PartialView/_CategoryMessages" />
    <partial name="PartialView/_CategoryForm" model="Model ?? new CategoryVM()" />
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
