@using MyShop.BLL.Models.Dto.CategoryDto
@model IEnumerable<CategoryDto>

@{
    Layout = "~/Views/Shared/_Dashboard.cshtml";
    ViewBag.PageTitle = "Category Management";
    ViewBag.CardTitle = "Categories";
    var categories = (Model ?? Enumerable.Empty<CategoryDto>()).ToList();
}

<partial name="_CategoryStyles" />

<section class="catalog-shell">
    <partial name="_CategoryMessages" />

    <div class="catalog-toolbar">
        <div>
            <span class="catalog-kicker">Catalog taxonomy</span>
            <h2>Product Categories</h2>
            <p>Organize the storefront into clean buying paths for customers.</p>
        </div>
        <a asp-action="Create" class="catalog-primary-action">
            <i class="fas fa-plus"></i>
            <span>New Category</span>
        </a>
    </div>

    <div class="catalog-metrics">
        <div class="catalog-metric">
            <span>Total categories</span>
            <strong>@categories.Count</strong>
        </div>
        <div class="catalog-metric">
            <span>Active navigation groups</span>
            <strong>@categories.Count</strong>
        </div>
    </div>

    @if (categories.Any())
    {
        <div class="catalog-table-wrap">
            <table class="catalog-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Status</th>
                        <th class="catalog-actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in categories)
                    {
                        var initial = string.IsNullOrWhiteSpace(category.Name) ? "?" : category.Name.Substring(0, 1).ToUpper();
                        <tr>
                            <td>
                                <div class="category-cell">
                                    <span class="category-avatar">@initial</span>
                                    <div>
                                        <strong>@category.Name</strong>
                                        <small>ID: @category.Id</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="catalog-status">
                                    <i class="fas fa-check-circle"></i>
                                    Active
                                </span>
                            </td>
                            <td>
                                <div class="catalog-actions">
                                    <a asp-action="Edit" asp-route-id="@category.Id" class="catalog-icon-action" title="Edit category">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@category.Id" class="catalog-icon-action danger" title="Delete category">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="catalog-empty">
            <i class="fas fa-tags"></i>
            <h3>No categories yet</h3>
            <p>Create the first category to start arranging your product catalog.</p>
            <a asp-action="Create" class="catalog-primary-action">
                <i class="fas fa-plus"></i>
                <span>Create Category</span>
            </a>
        </div>
    }
</section>
