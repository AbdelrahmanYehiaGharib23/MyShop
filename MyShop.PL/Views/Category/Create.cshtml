@using MyShop.PL.ViewModels
@model CategoryVM

@{
    Layout = "~/Views/Shared/_Dashboard.cshtml";
    ViewBag.PageTitle = "Category Management";
    ViewBag.CardTitle = "Create Category";
    ViewData["FormMode"] = "Create";
    ViewData["FormAction"] = "Create";
    ViewData["SubmitText"] = "Create Category";
    ViewData["FormIntro"] = "Add a clear category name that customers can scan quickly.";
}

<partial name="_CategoryStyles" />

<section class="catalog-shell catalog-narrow">
    <partial name="_CategoryMessages" />
    <partial name="_CategoryForm" model="Model ?? new CategoryVM()" />
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
